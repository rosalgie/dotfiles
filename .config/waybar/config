  },
  "custom/headphone-battery": {
    "format": "{}",
    "interval": 3,
    "exec": "~/.config/waybar/scripts/get-headphone-battery.sh",
    "return-type": "json",
  },
  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{icon} ({signalStrength}%)",
    "format-ethernet": "ŅĮä  ({signalStrength}%)",
