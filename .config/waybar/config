{
  // "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "height": 35, // Waybar height (to be removed for auto height)
  // "width": 1920, // Waybar width
  // Choose the order of the modules
  "modules-left": ["tray", "hyprland/workspaces", "pulseaudio"],
  "modules-center": ["custom/media"],
  // "modules-center": ["mpd"],
  "modules-right": ["network", "custom/headphone-battery", "battery", "backlight", "clock"],
  // Modules configuration
  "custom/media": {
    "exec": "/usr/bin/python3 $HOME/.local/bin/mediaplayer.py",
    "return-type": "json",
    "max-length": 70,
    "on-click": "playerctl play-pause",
    "escape": "true",
  },
  "mpd": {
    "format": "{stateIcon} {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S})",
    "format-disconnected": "",
    "format-stopped": "",
    "interval": 1,
    "on-click": "playerctl -p mpd play-pause",
    "consume-icons": {
      "on": "’āä " // Icon shows only when "consume" is on
    },
    "random-icons": {
      "off": "<span color='#f53c3c'>’ü┤</span> ", // Icon grayed out when "random" is off
      "on": "’ü┤ "
    },
    "repeat-icons": {
      "on": "’Ć× "
    },
    "single-icons": {
      "on": "’Ć×1 "
    },
    "state-icons": {
      "paused": "’üī",
      "playing": "’üŗ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "urgent": "’ü¬",
      "focused": "’åÆ",
      "default": "’äæ"
    },
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    }
  },
  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "interval": 1,
    "format": "{:%Y-%m-%d %I:%M:%S %p }",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click": "mode",
    }
  },
  "temperature": {
    "thermal-zone": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 90,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureF}┬░C {icon}",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },
  "backlight": {
    "scroll-step": 5, // %, can be a float
    "device": "intel_backlight",
    "format": "’åģ  {percent}%"
  },
  "battery": {
    "interval": 3,
    "states": {
      "good": 95,
      "warning": 45,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    // "format-charging": "¾░éä {capacity}%",
    "format-plugged": "’ć” {capacity}%",
    "format-alt": "{icon} {time}",
