      "hands-free": "¾▒ĪÅ ",
      "headset": "¾░ŗÄ ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["’Ć”", "’Ć¦ ", "’Ć© "]
    },
    "on-click": "pavucontrol"
  },
}
